{
  "manifest_version": 3,
  "name": "Coupon Clipper Extension",
  "version": "0.1.5",
  "description": "Personal helper for clipping visible digital coupons.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.bjs.com/*",
    "https://global.americanexpress.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "coupon-clipper@kamleshkc2002.github.io",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "142.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.bjs.com/*",
        "https://global.americanexpress.com/*"
      ],
      "js": ["sites.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Coupon Clipper",
    "default_popup": "popup.html"
  }
}
