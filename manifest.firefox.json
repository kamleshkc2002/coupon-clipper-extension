{
  "manifest_version": 3,
  "name": "Coupon Clipper Extension",
  "version": "0.1.2",
  "description": "Personal helper for clipping visible digital coupons.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://www.bjs.com/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "coupon-clipper@kamleshkc2002.github.io",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "142.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.bjs.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Coupon Clipper",
    "default_popup": "popup.html"
  }
}
